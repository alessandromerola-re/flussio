PORT=4000
DATABASE_URL=postgres://flussio:CHANGE_ME_DB_PASSWORD@db:5432/flussio
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_SECRET
# Comma-separated origins, no wildcard in production
CORS_ORIGINS=https://app.example.com

# Production-first bootstrap (created only when users table is empty)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Primary Admin
BOOTSTRAP_COMPANY_NAME=My Company

# Development seed (disabled by default; enable only for local dev)
ENABLE_DEV_SEED=false
DEV_USER_EMAIL=dev@flussio.local
DEV_USER_PASSWORD=
DEV_COMPANY_NAME=Flussio Demo

# Recurring generator
RECURRING_GENERATOR_ENABLED=true
RECURRING_GENERATOR_INTERVAL_MIN=5

RESET_EMAIL_ENABLED=false
ATTACHMENT_MAX_MB=20
SHOW_ROADMAP=false
