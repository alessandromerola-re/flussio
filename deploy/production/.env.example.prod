# Flussio production environment template.
# Copy this file to .env and customize values before first start.

# Release tag used for immutable production deploys (example: v1.1.1)
FLUSSIO_VERSION=v1.1.0

# GHCR coordinates
GHCR_OWNER=your-github-org-or-user
GHCR_REPO=flussio

# Frontend host bind
FRONTEND_HOST_PORT=9808

# Postgres
POSTGRES_DB=flussio
POSTGRES_USER=flussio
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# Backend runtime
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_SECRET
CORS_ORIGINS=https://app.example.com
ATTACHMENT_MAX_MB=20
RECURRING_GENERATOR_ENABLED=false
RECURRING_GENERATOR_INTERVAL_MIN=5

# First bootstrap admin (used only when DB has no users)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_MIN_16_CHARS
BOOTSTRAP_ADMIN_NAME=Primary Admin
BOOTSTRAP_COMPANY_NAME=My Company

# Optional: set compose variant used by helper scripts.
# The official installation path is direct docker compose commands.
# FLUSSIO_COMPOSE_FILE=docker-compose.prod.yml
